function copyLine(){
  const txt=document.getElementById('line-txt').value;
  navigator.clipboard?.writeText(txt).then(()=>toast('✅ 已複製，開啟 LINE 貼上即可','success')).catch(()=>{
    document.getElementById('line-txt').select(); document.execCommand('copy'); toast('✅ 已複製','success');
  });
}

// ═══════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════
async function requestPerm(){
  if(!('Notification' in window)){ toast('此瀏覽器不支援通知','error');return; }
  const r=await Notification.requestPermission();
  updateNotifUI(); renderDash();
  if(r==='granted'){
    toast('🔔 通知已開啟！','success');
    new Notification('🛡 保險CRM',{body:'系統將在保單到期前自動提醒您',tag:'welcome'});
  } else { toast('請至設定 → Safari → 通知，手動允許','warning'); }
}

function pushNotif(){
  if(Notification.permission!=='granted'){ requestPerm();return; }
  const exp=expiring().filter(p=>p.dl>=0&&p.dl<=30);
  if(!exp.length){ toast('目前無近期到期保單','warning');return; }
  exp.forEach((p,i)=>setTimeout(()=>{
    new Notification(`${p.dl<=2?'🚨':p.dl<=10?'⚠️':'📅'} ${cn(p.cid)} — ${p.type}`,{body:`保單${p.num} 到期${fd(p.end)}（剩${p.dl}天）\n保費 ${fa(p.prem)}`,tag:`p-${p.id}`,requireInteraction:p.dl<=2});
  },i*500));
  toast(`🔔 已推送 ${exp.length} 筆通知`,'success');
}

function testNotif(){
  if(Notification.permission!=='granted'){ requestPerm();return; }
  new Notification('🛡 保險CRM 測試',{body:'推播通知正常運作！',tag:'test'});
  toast('✅ 測試通知已發送','success');
}

function updateNotifUI(){
  const perm=typeof Notification!=='undefined'?Notification.permission:'denied';
  const el=document.getElementById('notif-status-set');
  if(!el)return;
  const status={
    granted:`<div style="background:var(--green-bg);border-radius:10px;padding:10px 13px;font-size:13px;color:var(--green);display:flex;gap:8px;align-items:center"><span>✅</span>通知已開啟，系統將自動提醒您</div>`,
    denied:`<div style="background:var(--red-bg);border-radius:10px;padding:10px 13px;font-size:13px;color:var(--red)">❌ 通知已封鎖。<br>請至 設定 → Safari → 通知 → 手動允許</div>`,
    default:`<div style="background:var(--surface2);border-radius:10px;padding:10px 13px;font-size:13px;color:var(--text2)">尚未開啟通知，點下方按鈕授權</div>`
  };
  el.innerHTML=status[perm]||status.default;
}

function dailyCheck(){
  const today=new Date().toDateString();
  if(localStorage.getItem('crm-last-chk')===today)return;
  const now=new Date();
  const [hh]=(db.settings.checkTime||'09:00').split(':').map(Number);
  if(now.getHours()<hh)return;
  localStorage.setItem('crm-last-chk',today);
  const exp=expiring().filter(p=>p.dl>=0&&RDAYS.includes(p.dl));
  if(exp.length){ toast(`🔔 今日有 ${exp.length} 張保單到達提醒節點`,'info'); if(Notification.permission==='granted') setTimeout(pushNotif,2000); }
}

