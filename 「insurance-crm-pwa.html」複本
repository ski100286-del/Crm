// INSTALL BANNER (iOS Add to Home Screen)
// ═══════════════════════════════════════════
function checkInstall(){
  const iOS=/iphone|ipad|ipod/i.test(navigator.userAgent);
  const standalone=window.navigator.standalone;
  const dismissed=localStorage.getItem('install-dismissed');
  const iw=document.getElementById('install-wrap');
  if(!iw)return;
  if(iOS&&!standalone&&!dismissed){
    iw.innerHTML=`<div class="install-banner" style="margin-bottom:0">
      <div class="bi">📲</div>
      <div style="flex:1">
        <h4>加入主畫面，像App一樣使用</h4>
        <p>點 Safari 底部 ⎙ → 加入主畫面 → 加入</p>
      </div>
      <button class="close-btn" onclick="dismissInstall()">✕</button>
    </div><div style="height:14px"></div>`;
  }
}
function dismissInstall(){ localStorage.setItem('install-dismissed','1'); document.getElementById('install-wrap').innerHTML=''; }

// ═══════════════════════════════════════════
// SHEET HELPERS
// ═══════════════════════════════════════════
function os(id){ document.getElementById(id).classList.add('open'); }
function cs(id){ document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.sheet-overlay').forEach(el=>{
  el.addEventListener('click',e=>{ if(e.target===el) el.classList.remove('open'); });
});
// Swipe down to close sheets
document.querySelectorAll('.sheet').forEach(sheet=>{
  let startY=0;
  sheet.addEventListener('touchstart',e=>{ startY=e.touches[0].clientY; },{passive:true});
  sheet.addEventListener('touchend',e=>{
    const diff=e.changedTouches[0].clientY-startY;
    if(diff>60&&sheet.scrollTop===0) sheet.closest('.sheet-overlay')?.classList.remove('open');
  },{passive:true});
});

// ═══════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════
function toast(msg,type=''){
  const el=document.createElement('div');
  el.className='toast '+(type||'');
  el.innerHTML=`<span>${type==='success'?'✓':type==='error'?'✕':type==='warning'?'⚠':'ℹ'}</span><span style="flex:1">${msg}</span>`;
  document.getElementById('toast-wrap').appendChild(el);
  setTimeout(()=>{ el.style.animation='toastOut .2s ease forwards'; setTimeout(()=>el.remove(),200); },3500);
}

