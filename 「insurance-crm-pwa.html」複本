function savePolicy(){
  const cid=document.getElementById('p-client').value;
  const num=document.getElementById('p-num').value.trim();
  const end=document.getElementById('p-end').value;
  if(!cid){ toast('請選擇客戶','error');return; }
  if(!num){ toast('請輸入保單號碼','error');return; }
  if(!end){ toast('請輸入到期日','error');return; }
  const data={cid,num,type:document.getElementById('p-type').value,prem:document.getElementById('p-prem').value,start:document.getElementById('p-start').value,end,co:document.getElementById('p-co').value.trim(),item:document.getElementById('p-item').value.trim(),note:document.getElementById('p-note').value.trim()};
  if(ePol){ const i=db.policies.findIndex(p=>p.id===ePol); if(i>=0) db.policies[i]={...db.policies[i],...data}; }
  else db.policies.push({id:uid(),...data,rs:{}});
