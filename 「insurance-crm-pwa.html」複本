function saveSettings(){ db.settings.checkTime=document.getElementById('chk-time').value; save();toast('設定已儲存 ✓','success'); }

function updateStorageInfo(){
  const size=new Blob([JSON.stringify(db)]).size;
  const el=document.getElementById('storage-info');
  if(el) el.textContent=`儲存大小：${(size/1024).toFixed(1)} KB｜客戶：${db.clients.length}人｜保單：${db.policies.length}張`;
}

function exportJSON(){
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(db,null,2)],{type:'application/json'}));
  a.download=`insurance-crm-${new Date().toISOString().split('T')[0]}.json`;
  a.click();
  toast('備份匯出成功','success');
}
function importJSON(e){
  const f=e.target.files[0]; if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{
    try{ const d=JSON.parse(ev.target.result);
      if(d.clients&&d.policies){ db=d;save();renderDash();toast('資料還原成功','success'); }
      else toast('格式不符','error');
    }catch{toast('匯入失敗','error')}
  };
  r.readAsText(f); e.target.value='';
}
function clearAll(){
  if(!confirm('⚠ 確定清除所有資料？'))return;
  db={clients:[],policies:[],history:[],settings:db.settings};
  save();renderDash();toast('已清除','error');
}

