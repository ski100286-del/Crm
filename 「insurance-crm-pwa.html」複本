}

// ═══════════════════════════════════════════
// ACTION SHEET
// ═══════════════════════════════════════════
function openActSheet(pid){
  curPol=pid; curAct=null;
  const p=db.policies.find(x=>x.id===pid);
  const rs=p?.rs||{};
  document.getElementById('act-info').innerHTML=`<strong>${cn(p?.cid)}</strong> — ${p?.type}<br><span style="color:var(--text2)">保單 ${p?.num}｜到期 ${fd(p?.end)}｜剩 ${daysLeft(p?.end)} 天</span>`;
  document.getElementById('act-note').value=rs.note||'';
  document.getElementById('retry-date').value=rs.retryDate||'';
  document.getElementById('retry-row').style.display='none';
  ['ab-done','ab-again','ab-fail'].forEach(id=>document.getElementById(id).classList.remove('on'));
  if(rs.act){ curAct=rs.act; document.getElementById({done:'ab-done',again:'ab-again',fail:'ab-fail'}[rs.act])?.classList.add('on'); if(rs.act==='again') document.getElementById('retry-row').style.display=''; }
  os('act-sheet');
}
function pickAct(a){
  curAct=a;
  ['ab-done','ab-again','ab-fail'].forEach(id=>document.getElementById(id).classList.remove('on'));
  document.getElementById({done:'ab-done',again:'ab-again',fail:'ab-fail'}[a])?.classList.add('on');
  document.getElementById('retry-row').style.display=a==='again'?'':'none';
}
function saveAction(){
  if(!curAct){ toast('請選擇聯繫結果','error');return; }
  const p=db.policies.find(x=>x.id===curPol); if(!p)return;
  if(!p.rs) p.rs={};
  p.rs.act=curAct;
  p.rs.note=document.getElementById('act-note').value.trim();
  p.rs.updAt=new Date().toISOString();
  if(curAct==='again') p.rs.retryDate=document.getElementById('retry-date').value;
  addHist(curPol,curAct,p.rs.note);
  save();cs('act-sheet');
  toast({done:'✅ 已完成',again:'🔄 設定再聯繫',fail:'❌ 未完成'}[curAct],curAct==='done'?'success':'warning');
  const cur=document.querySelector('.view.active')?.id?.replace('view-','');
  render(cur||'dashboard');
}

