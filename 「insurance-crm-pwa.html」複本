function saveClient(){
  const name=document.getElementById('c-name').value.trim();
  if(!name){ toast('請輸入客戶姓名','error');return; }
  const data={name,phone:document.getElementById('c-phone').value.trim(),line:document.getElementById('c-line').value.trim(),email:document.getElementById('c-email').value.trim(),birthday:document.getElementById('c-bday').value,job:document.getElementById('c-job').value.trim(),addr:document.getElementById('c-addr').value.trim(),note:document.getElementById('c-note').value.trim()};
