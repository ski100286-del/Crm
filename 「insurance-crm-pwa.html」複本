<script>
// ═══════════════════════════════════════════
// DATA
// ═══════════════════════════════════════════
let db = { clients:[], policies:[], history:[], settings:{checkTime:'09:00'} };
let ePol=null, eCli=null, curPol=null, curAct=null;
const RDAYS=[30,20,10,2];

function load(){
  try{ const s=localStorage.getItem('ins-crm'); if(s) db=JSON.parse(s); }catch(e){}
  if(!db.clients) db.clients=[];
  if(!db.policies) db.policies=[];
  if(!db.history) db.history=[];
  if(!db.settings) db.settings={checkTime:'09:00'};
  document.getElementById('chk-time').value=db.settings.checkTime||'09:00';
  if(db.clients.length===0) seed();
  checkInstall();
}

function save(){ localStorage.setItem('ins-crm',JSON.stringify(db)); updateStorageInfo(); }

function seed(){
  db.clients=[
    {id:'c1',name:'王小明',phone:'0912-345-678',line:'ming_wang',email:'ming@example.com',birthday:'1980-05-15',job:'工程師',addr:'台北市信義區',note:'注重服務品質'},
    {id:'c2',name:'李美華',phone:'0923-456-789',line:'lisa_lee',email:'',birthday:'1975-11-22',job:'教師',addr:'新北市板橋區',note:'每年固定續保'},
    {id:'c3',name:'陳建國',phone:'0934-567-890',line:'',email:'',birthday:'1990-03-08',job:'商人',addr:'台中市西區',note:'偏好電話聯繫'},
    {id:'c4',name:'張淑芬',phone:'0956-789-012',line:'sophia_chang',email:'sophia@gmail.com',birthday:'1985-07-30',job:'護理師',addr:'高雄市前鎮區',note:''},
  ];
  const ad=n=>{const d=new Date();d.setDate(d.getDate()+n);return d.toISOString().split('T')[0]};
  db.policies=[
    {id:'p1',cid:'c1',num:'AB12345678',type:'汽機車險',prem:18500,start:ad(-335),end:ad(30),co:'富邦產險',item:'ABC-1234 Toyota Camry',note:'含甲式車體險',rs:{}},
    {id:'p2',cid:'c2',num:'CD98765432',type:'火險',prem:8800,start:ad(-345),end:ad(20),co:'國泰產險',item:'府中路住宅',note:'',rs:{}},
    {id:'p3',cid:'c3',num:'EF11223344',type:'健康險',prem:32000,start:ad(-355),end:ad(10),co:'新光產險',item:'住院醫療綜合險',note:'含實支實付',rs:{}},
    {id:'p4',cid:'c4',num:'GH55667788',type:'汽機車險',prem:15200,start:ad(-363),end:ad(2),co:'泰安產險',item:'XYZ-5678 Honda CR-V',note:'',rs:{}},
    {id:'p5',cid:'c1',num:'IJ99001122',type:'旅遊險',prem:1200,start:ad(-180),end:ad(185),co:'富邦產險',item:'海外旅遊綜合險',note:'',rs:{}},
    {id:'p6',cid:'c2',num:'KL33445566',type:'壽險',prem:48000,start:ad(-400),end:ad(-35),co:'南山人壽',item:'終身壽險',note:'',rs:{}},
  ];
  save();
}

// ═══════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════
function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,5) }
function daysLeft(d){ const a=new Date();a.setHours(0,0,0,0);const b=new Date(d);b.setHours(0,0,0,0);return Math.ceil((b-a)/86400000) }
function cn(cid){ const c=db.clients.find(x=>x.id===cid);return c?c.name:'—' }
function cc(cid){ return db.clients.find(x=>x.id===cid) }
function fd(d){ return d?d.replace(/-/g,'/'):'-' }
function fa(n){ return n?Number(n).toLocaleString()+' 元':'-' }
function expiring(){ return db.policies.map(p=>({...p,dl:daysLeft(p.end)})).filter(p=>p.dl<=30&&p.dl>=-30).sort((a,b)=>a.dl-b.dl) }
function tc(t){ return {'汽機車險':'tc-car','火險':'tc-fire','健康險':'tc-health','旅遊險':'tc-travel','壽險':'tc-life','海上貨運險':'tc-marine'}[t]||'' }

function dayBadge(dl){
  if(dl<0) return `<span class="badge b-gray">過期${Math.abs(dl)}天</span>`;
  if(dl<=2) return `<span class="badge b-red">⚠ 剩${dl}天</span>`;
  if(dl<=10) return `<span class="badge b-orange">剩${dl}天</span>`;
  if(dl<=20) return `<span class="badge b-amber">剩${dl}天</span>`;
  return `<span class="badge b-blue">剩${dl}天</span>`;
}

function stBadge(rs){
  if(!rs?.act) return '';
  return {done:'<span class="badge b-green">✅ 已完成</span>',again:'<span class="badge b-amber">🔄 再聯繫</span>',fail:'<span class="badge b-red">❌ 未完成</span>'}[rs.act]||'';
}

function addHist(pid,act,note){
  const p=db.policies.find(x=>x.id===pid);
  db.history.unshift({id:uid(),pid,cn:cn(p?.cid),pt:p?.type,pn:p?.num,act,note,ts:new Date().toISOString()});
  if(db.history.length>300) db.history=db.history.slice(0,300);
}

// ═══════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════
function go(name){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  document.getElementById('tab-'+name)?.classList.add('active');
  document.getElementById('main-content').scrollTop=0;
  render(name);
}

function render(n){
  if(n==='dashboard') renderDash();
  if(n==='reminders') renderRem();
  if(n==='clients') renderClients();
  if(n==='policies') renderPolicies();
  if(n==='settings'){ updateNotifUI(); updateStorageInfo(); }
}

// ═══════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════
function renderDash(){
  const exp=expiring();
  const urgent=exp.filter(p=>p.dl>=0&&p.dl<=2).length;
  const soon=exp.filter(p=>p.dl>=0&&p.dl<=30).length;
  const active=db.policies.filter(p=>daysLeft(p.end)>=0).length;
  const prem=db.policies.filter(p=>daysLeft(p.end)>=0).reduce((s,p)=>s+(Number(p.prem)||0),0);

  document.getElementById('stats-row').innerHTML=`
    <div class="stat-card s-red"><div class="stat-lbl">🚨 緊急（2天內）</div><div class="stat-val" style="color:var(--red)">${urgent}</div><div class="stat-sub">需立即聯繫</div></div>
    <div class="stat-card s-orange"><div class="stat-lbl">📅 近期（30天）</div><div class="stat-val" style="color:var(--orange)">${soon}</div><div class="stat-sub">待追蹤</div></div>
    <div class="stat-card s-green"><div class="stat-lbl">📋 有效保單</div><div class="stat-val" style="color:var(--green)">${active}</div><div class="stat-sub">共${db.policies.length}張</div></div>
    <div class="stat-card s-blue"><div class="stat-lbl">💰 有效保費</div><div class="stat-val" style="color:var(--accent);font-size:18px">${prem.toLocaleString()}</div><div class="stat-sub">元</div></div>
  `;

  updateBadges();

  // Notification prompt
  const ndash=document.getElementById('notif-card-dash');
  if(Notification.permission==='default'){
    ndash.innerHTML=`<div class="perm-card">
      <div class="pi">🔔</div>
      <div style="flex:1"><h4>開啟到期推播通知</h4><p>保單到期前30/20/10/2天自動提醒</p></div>
      <button class="btn btn-sm" onclick="requestPerm()">開啟</button>
    </div>`;
  } else { ndash.innerHTML=''; }

  const top=exp.filter(p=>p.dl>=0).slice(0,8);
  if(!top.length){
    document.getElementById('dash-cards').innerHTML='<div class="empty"><div class="empty-icon">🎉</div><p>近期無到期保單</p></div>';
    return;
  }
  document.getElementById('dash-cards').innerHTML=top.map(p=>policyCard(p,true)).join('');
}

// ═══════════════════════════════════════════
// REMINDERS
// ═══════════════════════════════════════════
function renderRem(){
  const exp=expiring();
  if(!exp.length){ document.getElementById('rem-content').innerHTML='<div class="empty"><div class="empty-icon">✅</div><p>目前沒有到期提醒</p></div>';return; }
  const groups=[
    {label:'🚨 到期前2天（緊急）',items:exp.filter(p=>p.dl>=0&&p.dl<=2)},
    {label:'🔴 到期前10天',items:exp.filter(p=>p.dl>2&&p.dl<=10)},
    {label:'🟠 到期前20天',items:exp.filter(p=>p.dl>10&&p.dl<=20)},
    {label:'🟡 到期前30天',items:exp.filter(p=>p.dl>20&&p.dl<=30)},
    {label:'⚫ 已過期',items:exp.filter(p=>p.dl<0)},
  ];
  let html='';
  for(const g of groups){
    if(!g.items.length) continue;
    html+=`<div class="group-label">${g.label} (${g.items.length})</div>`;
    html+=g.items.map(p=>policyCard(p,true)).join('');
  }
  document.getElementById('rem-content').innerHTML=html;
}

function policyCard(p, showActions=false){
  const cl=cc(p.cid);
  const border=p.dl>=0&&p.dl<=2?'urg':p.dl>=0&&p.dl<=10?'warn':'';
  const rs=p.rs||{};
  return `<div class="policy-card ${border}">
    <div class="card-body">
      <div class="card-top">
        <div>
          <div class="card-name">${cn(p.cid)}</div>
          ${cl?.phone?`<div style="font-size:12px;color:var(--text3)">${cl.phone}</div>`:''}
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px">
          <span class="badge card-type ${tc(p.type)}">${p.type}</span>
          ${dayBadge(p.dl)}
        </div>
      </div>
      <div class="card-meta">
        <span>📋 <strong>${p.num}</strong></span>
        <span>🏢 ${p.co||'—'}</span>
        <span>📅 ${fd(p.end)}</span>
        <span>💰 ${fa(p.prem)}</span>
        ${cl?.line?`<span>🟢 ${cl.line}</span>`:''}
      </div>
      ${rs.note?`<div style="font-size:12px;color:var(--accent);margin-bottom:8px">💬 ${rs.note}</div>`:''}
      ${rs.retryDate?`<div style="font-size:12px;color:var(--amber);margin-bottom:8px">🗓 再聯繫：${fd(rs.retryDate)}</div>`:''}
      ${stBadge(rs)}
      ${showActions?`
      <div style="margin-top:10px;display:flex;gap:6px;flex-wrap:wrap">
        <button class="btn btn-xs ${rs.act==='done'?'btn-green':''}" onclick="quickAct('${p.id}','done')">✅ 完成</button>
        <button class="btn btn-xs ${rs.act==='again'?'btn-primary':''}" onclick="quickAct('${p.id}','again')">🔄 再聯繫</button>
        <button class="btn btn-xs ${rs.act==='fail'?'btn-red':''}" onclick="quickAct('${p.id}','fail')">❌ 未完成</button>
        <button class="btn btn-xs" onclick="openActSheet('${p.id}')">📝 記錄</button>
        <button class="btn btn-xs" onclick="lineDraft('${p.id}')">📱 LINE</button>
      </div>`:''}
    </div>
  </div>`;
}

function quickAct(pid,act){
  const p=db.policies.find(x=>x.id===pid); if(!p)return;
  if(!p.rs) p.rs={};
  p.rs.act=act; p.rs.updAt=new Date().toISOString();
  addHist(pid,act,''); save();
  const lbl={done:'✅ 已完成',again:'🔄 再聯繫',fail:'❌ 未完成'};
  toast(lbl[act],act==='done'?'success':act==='again'?'warning':'error');
  const cur=document.querySelector('.view.active')?.id?.replace('view-','');
  render(cur||'dashboard');
}

// ═══════════════════════════════════════════
// CLIENTS
// ═══════════════════════════════════════════
function renderClients(){
  const q=(document.getElementById('cl-search')?.value||'').toLowerCase();
  const list=db.clients.filter(c=>!q||c.name.toLowerCase().includes(q)||(c.phone||'').includes(q));
  const el=document.getElementById('cl-list');
  if(!list.length){ el.innerHTML='<div class="empty"><div class="empty-icon">👥</div><p>尚無客戶</p></div>';return; }
  el.innerHTML=list.map(c=>{
    const pc=db.policies.filter(p=>p.cid===c.id).length;
    return `<div class="policy-card">
      <div class="card-body">
        <div class="card-top">
          <div>
            <div class="card-name">${c.name}</div>
            ${c.job?`<div style="font-size:12px;color:var(--text3)">${c.job}</div>`:''}
          </div>
          <span class="badge b-blue">${pc} 張保單</span>
        </div>
        <div class="card-meta">
          ${c.phone?`<span>📞 ${c.phone}</span>`:''}
          ${c.line?`<span>🟢 ${c.line}</span>`:''}
          ${c.birthday?`<span>🎂 ${fd(c.birthday)}</span>`:''}
        </div>
        ${c.note?`<div style="font-size:12px;color:var(--text2);margin-top:4px">${c.note}</div>`:''}
