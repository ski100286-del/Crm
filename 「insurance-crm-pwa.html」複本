function delClient(id){
  if(!confirm('確定刪除此客戶？')) return;
  db.clients=db.clients.filter(c=>c.id!==id);
  db.policies=db.policies.filter(p=>p.cid!==id);
  save();renderClients();toast('已刪除','error');
}

// ═══════════════════════════════════════════
// POLICIES
// ═══════════════════════════════════════════
function renderPolicies(){
  const q=(document.getElementById('po-search')?.value||'').toLowerCase();
  const tf=document.getElementById('po-type')?.value||'';
  let list=db.policies.map(p=>({...p,dl:daysLeft(p.end)}));
  if(q) list=list.filter(p=>cn(p.cid).toLowerCase().includes(q)||(p.num||'').toLowerCase().includes(q));
  if(tf) list=list.filter(p=>p.type===tf);
  list.sort((a,b)=>a.dl-b.dl);
  const el=document.getElementById('po-list');
  if(!list.length){ el.innerHTML='<div class="empty"><div class="empty-icon">📋</div><p>無符合保單</p></div>';return; }
  el.innerHTML=list.map(p=>{
    const rs=p.rs||{};
    const border=p.dl>=0&&p.dl<=2?'urg':p.dl>=0&&p.dl<=10?'warn':'';
    return `<div class="policy-card ${border}">
      <div class="card-body">
        <div class="card-top">
          <div><div class="card-name">${cn(p.cid)}</div><div style="font-size:12px;color:var(--text3);font-family:monospace">${p.num}</div></div>
          <div style="text-align:right;display:flex;flex-direction:column;gap:4px;align-items:flex-end">
            <span class="badge ${tc(p.type)}">${p.type}</span>
            ${dayBadge(p.dl)}
          </div>
        </div>
        <div class="card-meta">
          <span>📅 ${fd(p.end)}</span>
          <span>💰 ${fa(p.prem)}</span>
          <span>🏢 ${p.co||'—'}</span>
        </div>
        ${stBadge(rs)}
        <div style="margin-top:10px;display:flex;gap:5px;flex-wrap:wrap">
          <button class="btn btn-xs" onclick="openActSheet('${p.id}')">📝 記錄</button>
          <button class="btn btn-xs" onclick="lineDraft('${p.id}')">📱 LINE</button>
          <button class="btn btn-xs" onclick="openEditPolicy('${p.id}')">✏ 編輯</button>
          <button class="btn btn-xs btn-red" onclick="delPolicy('${p.id}')">✕</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

